# RSS Feeder Environment Configuration
# Copy this to .env and fill in values

# API key for health/metrics endpoints
API_KEY=change-me-in-production

# Kafka configuration
KAFKA_BROKER_URL=kafka:9092
KAFKA_DEAD_LETTER_TOPIC=dead_letter_articles
SEND_TO_DEAD_LETTER_TOPIC=true

# Storage paths
FAILED_ARTICLES_FOLDER=data/failed_articles
INVALID_ARTICLES_LOG=data/logs/invalid_articles.log

# Prometheus
PROMETHEUS_MULTIPROC_DIR=/tmp
prometheus_multiproc_dir=/tmp

# Uvicorn
UVICORN_ACCESS_LOG=true
